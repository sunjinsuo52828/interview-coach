# Interview Coach 环境变量配置

# ============ GLM-4.5 API ============
# 获取API密钥: 访问 https://open.bigmodel.cn/ 注册并获取
GLM_API_KEY=your_glm_api_key_here
# 模型选择: glm-4-flash(快速, 推荐), glm-4.5(强大但较慢)
GLM_MODEL=glm-4-flash

# ============ 应用配置 ============
APP_ENV=development
APP_PORT=8501
APP_LOG_LEVEL=DEBUG

# ============ 数据存储 ============
DATA_DIR=./data
INTERVIEW_DIR=./data/interviews
QUESTION_BANK_DIR=./data/question_bank
KNOWLEDGE_BASE_DIR=./data/knowledge_base
CHROMA_DB_DIR=./data/chroma_db

# ============ Agent配置 ============
MAX_CONTEXT_LENGTH=180000
SUMMARY_INTERVAL=10
MAX_FOLLOW_UP_DEPTH=3

# ============ 默认配置 ============
DEFAULT_INTERVIEWER_LEVEL=senior_engineer
DEFAULT_INTERVIEW_DURATION=45
DEFAULT_LANGUAGE=zh
